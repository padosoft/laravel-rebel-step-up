{
    "name": "padosoft/laravel-rebel-step-up",
    "description": "Step-up authentication per Laravel Rebel: conferma di un'azione/purpose con assurance AAL/AMR, risk-based, e PSD2/SCA dynamic linking. Parte di padosoft/laravel-rebel-*.",
    "keywords": ["laravel", "authentication", "step-up", "mfa", "sca", "psd2", "assurance", "padosoft", "rebel"],
    "homepage": "https://github.com/padosoft/laravel-rebel-step-up",
    "license": "MIT",
    "authors": [
        {
            "name": "Padosoft",
            "email": "support@padosoft.com",
            "homepage": "https://www.padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "padosoft/laravel-rebel-core": "^0.1",
        "padosoft/laravel-rebel-email-otp": "^0.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/padosoft/laravel-rebel-core" },
        { "type": "vcs", "url": "https://github.com/padosoft/laravel-rebel-email-otp" }
    ],
    "autoload": {
        "psr-4": {
            "Padosoft\\Rebel\\StepUp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\Rebel\\StepUp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Rebel\\StepUp\\RebelStepUpServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "check": [
            "@pint --test",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
