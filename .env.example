# ============================================================================
# laravel-rebel-step-up — environment variables
# Copy the useful values into your application's .env. Do NOT commit secrets.
# ============================================================================

# --- Keyed hashing (shared with the core): needed for PSD2/SCA dynamic linking ---
# The pepper version currently in use (integer).
REBEL_PEPPER_CURRENT=1
# The pepper secret(s), one per version. MUST be long and random.
# In production use a real secret and keep it out of version control.
REBEL_PEPPER_1=change-this-with-a-long-and-random-secret

# --- Step-up (all optional: they have sensible defaults in config/rebel-step-up.php) ---
# Default confirmation window, in seconds (how long a confirmation stays valid).
REBEL_STEPUP_TTL=600
# Expiry of the single challenge, in seconds (how long you have to enter the code).
REBEL_STEPUP_CHALLENGE_TTL=300
# Wrong attempts before marking the challenge as "failed".
REBEL_STEPUP_MAX_ATTEMPTS=5
# Route name of the confirmation page for web (non-JSON) requests.
# Leave empty to respond with a "bare" 423.
REBEL_STEPUP_REDIRECT_ROUTE=
