# ============================================================================
# laravel-rebel-step-up — variabili d'ambiente
# Copia i valori utili nel .env della tua applicazione. NON committare i segreti.
# ============================================================================

# --- Hashing keyed (condiviso col core): serve al PSD2/SCA dynamic linking ---
# Versione del pepper attualmente in uso (intero).
REBEL_PEPPER_CURRENT=1
# Il/i segreto/i pepper, uno per versione. DEVE essere lungo e casuale.
# In produzione usa un segreto vero e tienilo fuori dal version control.
REBEL_PEPPER_1=cambia-questo-con-un-segreto-lungo-e-casuale

# --- Step-up (tutte opzionali: hanno default sensati in config/rebel-step-up.php) ---
# Finestra di conferma di default, in secondi (quanto resta valida una conferma).
REBEL_STEPUP_TTL=600
# Scadenza della singola sfida, in secondi (entro quanto inserire il codice).
REBEL_STEPUP_CHALLENGE_TTL=300
# Tentativi sbagliati prima di marcare la sfida come "failed".
REBEL_STEPUP_MAX_ATTEMPTS=5
# Route name della pagina di conferma per le richieste web (non-JSON).
# Lascia vuoto per rispondere con un 423 "nudo".
REBEL_STEPUP_REDIRECT_ROUTE=
